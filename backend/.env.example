# Get these from Supabase Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Service role key — server-side ONLY. Never ship this in the mobile app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

PORT=4000

# Comma-separated list of allowed origins (your Expo dev URL, vendor web dashboard, etc.)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Only needed if you run scripts/importFromGooglePlaces.js (onboarding path B).
# Get a free key at console.cloud.google.com — enable "Places API", $200/mo free credit.
GOOGLE_PLACES_API_KEY=your-google-places-api-key
